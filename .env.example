# === DATABASE ===
# DATABASE_URL should point to the database that has the live schema.
# DIRECT_URL should point to the direct database connection (5432) for Prisma.
DATABASE_URL=postgresql://user:pass@pooler-host:6543/dbname
DIRECT_URL=postgresql://user:pass@direct-host:5432/dbname
DATABASE_SSL_MODE=disable
PG_SSL_REJECT_UNAUTHORIZED=false

# === AUTH ===
JWT_SECRET=your-secret-key-at-least-43-characters-long-here
AUTH_ACCESS_TTL=12h
AUTH_REFRESH_TTL=7d
ACCOUNT_ACTION_TTL=24h
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=lax

# === AI (Groq) ===
GROQ_API_KEY=gsk_...

# === RATE LIMITING (Upstash Redis) ===
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
